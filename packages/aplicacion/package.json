{
  "name": "@ganaweb/aplicacion",
  "version": "0.0.0",
  "private": true,
  "description": "GanaWeb application layer. Port interfaces only (D6) — no use cases this change. Depends on dominio (entities) + sync (outbox shape); NOT db.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --allowOnly=false",
    "lint": "biome check ."
  },
  "dependencies": {
    "@ganaweb/dominio": "workspace:*",
    "@ganaweb/sync": "workspace:*"
  },
  "devDependencies": {
    "@ganaweb/config": "workspace:*",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
