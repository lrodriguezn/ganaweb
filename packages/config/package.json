{
  "name": "@ganaweb/config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript base + React + Biome preset for the ganaweb monorepo.",
  "type": "module",
  "files": [
    "tsconfig.base.json",
    "tsconfig.react.json",
    "biome-preset.json"
  ],
  "exports": {
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./tsconfig.react.json": "./tsconfig.react.json",
    "./biome-preset.json": "./biome-preset.json"
  },
  "scripts": {
    "build": "echo \"@ganaweb/config: no build step (config-only package)\"",
    "typecheck": "tsc --noEmit",
    "test": "echo \"@ganaweb/config: no tests\"",
    "lint": "biome check .",
    "ci": "pnpm run typecheck && pnpm run lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.2"
  }
}
