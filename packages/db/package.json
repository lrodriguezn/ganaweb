{
  "name": "@ganaweb/db",
  "version": "0.0.0",
  "private": true,
  "description": "GanaWeb persistence layer. Drizzle ORM, PostgreSQL 17 (online-first). Implements ports declared by aplicacion.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/schema/index.ts",
      "import": "./src/schema/index.ts"
    },
    "./auth-repository": {
      "types": "./src/auth-repository.ts",
      "import": "./src/auth-repository.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./animal-infrastructure": {
      "types": "./src/animal-infrastructure.ts",
      "import": "./src/animal-infrastructure.ts"
    },
    "./catalogo-global-infrastructure": {
      "types": "./src/catalogo-global-infrastructure.ts",
      "import": "./src/catalogo-global-infrastructure.ts"
    }
  },
  "scripts": {
    "build": "find src -name '*.ts' -o -name '*.tsx' 2>/dev/null | grep -q . && tsc --noEmit || echo 'no source files yet'",
    "typecheck": "find src -name '*.ts' -o -name '*.tsx' 2>/dev/null | grep -q . && tsc --noEmit || echo 'no source files yet'",
    "test": "vitest run --passWithNoTests --allowOnly=false",
    "test:watch": "vitest",
    "test:smoke": "DB_SMOKE=true vitest run",
    "coverage": "vitest run --coverage",
    "lint": "biome check .",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "push": "drizzle-kit push",
    "seed": "tsx src/seed/seed.ts"
  },
  "dependencies": {
    "@ganaweb/aplicacion": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@ganaweb/config": "workspace:*",
    "@types/node": "^24.13.0",
    "@vitest/coverage-v8": "^3.2.6",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
