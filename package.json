{
  "name": "ganaweb",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "GanaWeb — control ganadero bovino (Colombia). Clean/Hexagonal monorepo foundation.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": "24",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -F @ganaweb/web dev",
    "db:up": "bash scripts/db-up.sh",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome ci .",
    "format": "biome format --write .",
    "ci": "turbo run build typecheck test lint",
    "depcruise": "dependency-cruiser .",
    "parity:node-types": "node scripts/check-node-types-parity.mjs",
    "no-sqlite": "! grep -rE \"wa-sqlite|OPFS|sqlite-wasm|sql\\.js|better-sqlite3|@libsql|sqlite3|bun:sqlite\" --include=\"*.ts\" --include=\"*.tsx\" --include=\"*.js\" --include=\"*.json\" --include=\"*.yml\" --exclude-dir=node_modules --exclude-dir=.git --exclude=pnpm-lock.yaml . | grep -v \"^./package.json:.*no-sqlite:\" || (echo \"SQLite reference detected\" && exit 1)"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@ganaweb/config": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.0",
    "dependency-cruiser": "^16.10.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
