{
  "name": "@ganaweb/web",
  "version": "0.0.0",
  "private": true,
  "description": "GanaWeb TanStack Start app. Imports aplicacion + ui + db. NOT dominio (dependency-cruiser enforced).",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "tsr generate && vite build",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsr generate && tsc --noEmit",
    "test": "echo \"@ganaweb/web: integration via health-check script (PR5.T5)\"",
    "lint": "biome check .",
    "health-check": "node scripts/health-check.mjs",
    "generate-routes": "tsr generate"
  },
  "dependencies": {
    "@ganaweb/aplicacion": "workspace:*",
    "@ganaweb/db": "workspace:*",
    "@ganaweb/ui": "workspace:*",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@ganaweb/config": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-cli": "^1.167.18",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vite": "^7.0.0"
  }
}
