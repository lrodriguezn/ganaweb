{
  "name": "@ganaweb/web",
  "version": "0.0.0",
  "private": true,
  "description": "GanaWeb TanStack Start app. Imports aplicacion + ui + db. NOT dominio (dependency-cruiser enforced).",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "tsr generate && vite build",
    "start": "node scripts/server.mjs",
    "typecheck": "tsr generate && tsc --noEmit",
    "test": "tsx tests/auth-flow.test.ts && tsx tests/auth-scope-and-flow.test.ts && tsx tests/animal-web-flow.test.ts && vitest run",
    "test:unit": "tsx tests/auth-flow.test.ts && tsx tests/auth-scope-and-flow.test.ts && tsx tests/animal-web-flow.test.ts",
    "test:e2e": "vitest run",
    "lint": "biome check .",
    "health-check": "node scripts/health-check.mjs",
    "generate-routes": "tsr generate"
  },
  "dependencies": {
    "@ganaweb/aplicacion": "workspace:*",
    "@ganaweb/db": "workspace:*",
    "@ganaweb/ui": "workspace:*",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@ganaweb/config": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-cli": "^1.167.18",
    "@types/node": "^24.13.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vite": "^7.0.0",
    "vitest": "^3.2.6"
  }
}
