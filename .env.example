# =============================================================================
# GanaWeb — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# .env is git-ignored (.gitignore line 23).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (REQUIRED)
# -----------------------------------------------------------------------------
# PostgreSQL connection string used by Drizzle ORM (@ganaweb/db).
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ganaweb

# -----------------------------------------------------------------------------
# Node
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Server — apps/web (TanStack Start)
# -----------------------------------------------------------------------------
# HTTP port for the production server script (scripts/server.mjs).
# Vite dev server uses vite.config.ts → server.port (3000) instead.
PORT=3000

# Host bind address for the production server.
HOST=0.0.0.0

# Port used by the health-check script (scripts/health-check.mjs).
# Only needed if you change PORT above.
HEALTH_PORT=3000

# -----------------------------------------------------------------------------
# Seed
# -----------------------------------------------------------------------------
# Set to "true" to include demo data (fincas, usuarios de prueba, etc.)
# when running: pnpm --filter @ganaweb/db seed
SEED_DEMO=false

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
# Set to "true" to run DB smoke tests that require a live PostgreSQL:
#   pnpm --filter @ganaweb/db test:smoke
DB_SMOKE=false
